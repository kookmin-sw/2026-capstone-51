# 환경 변수 가이드.
#
# 파일 우선순위 (Vite): .env.local > .env (둘 다 gitignored).
# 이 .env.local.example 만 git tracked — 새 멤버가 보고 본인 .env 를 만든다.

# === 백엔드 API ===
# 백엔드 context-path 가 /api 라 끝에 /api 까지 포함해야 함.
# 실서버 (default): https://3.238.29.250/api  — 자체서명 인증서라 브라우저 첫 방문 시 "고급 → 진행" 한 번.
# 로컬 백엔드 띄울 때: http://localhost:8080/api
VITE_API_URL=https://3.238.29.250/api

# === Google OAuth (랜딩 → 로그인) ===
# 백엔드 팀이 Google Console 에 등록한 client_id 와 같아야 함.
# redirect_uri 는 Google Console 에 정확히 등록된 값이어야 함.
# 현재 등록 정책: http://localhost:3000/auth/callback (백엔드 환경변수 GOOGLE_REDIRECT_URI 와 일치).
# client_secret 은 백엔드만 보유 — 프론트는 공개해도 되는 client_id 만 사용.
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback
